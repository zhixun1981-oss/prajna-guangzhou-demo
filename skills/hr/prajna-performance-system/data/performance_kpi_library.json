            {"id": "KPI-MF-04", "name": "人员出勤率", "weight": 10, "target": "≥96%", "formula": "实际出勤工时/应出勤工时×100%", "source": "考勤系统", "rule": "每低1%扣2分，低于90%得0分", "cycle": "月度"},
            {"id": "KPI-MF-05", "name": "员工流失率", "weight": 5, "target": "≤5%/月", "formula": "离职人数/月初在岗人数×100%", "source": "HR系统", "rule": "每超1%扣2分，高于10%得0分", "cycle": "月度"},
            {"id": "KPI-MF-06", "name": "设备故障停机时间", "weight": 10, "target": "≤4小时/月", "formula": "∑本组责任停机小时数", "source": "设备维修单", "rule": "每超1小时扣2分，高于12小时得0分", "cycle": "月度"},
            {"id": "KPI-MF-07", "name": "安全事故", "weight": 10, "target": "0 起/月", "formula": "本组责任安全事故起数", "source": "安全报告", "rule": "每发生一起扣5分，重大事故0分", "cycle": "月度"},
            {"id": "KPI-MF-08", "name": "物料损耗率", "weight": 5, "target": "≤3%", "formula": "实际损耗/标准用量×100%", "source": "领料单/退料单", "rule": "每超0.5%扣2分，高于6%得0分", "cycle": "月度"}
          ]
        },
        "生产主管": {
          "kpis": [
            {"id": "KPI-MF-S01", "name": "生产计划达成率", "weight": 25, "target": "≥95%", "formula": "实际完成订单数/计划订单数×100%", "source": "ERP/MES", "rule": "每低1%扣2分，低于85%得0分", "cycle": "月度"},
            {"id": "KPI-MF-S02", "name": "产品一次合格率", "weight": 25, "target": "≥96%", "formula": "一次合格数/总产量×100%", "source": "质检报告", "rule": "每低0.5%扣3分，低于90%得0分", "cycle": "月度"},
            {"id": "KPI-MF-S03", "name": "单位生产成本", "weight": 15, "target": "≤预算100%", "formula": "实际成本/标准成本×100%", "source": "财务系统", "rule": "每超1%扣2分，高于110%得0分", "cycle": "月度"},
            {"id": "KPI-MF-S04", "name": "设备综合效率 OEE", "weight": 15, "target": "≥85%", "formula": "时间开动率×性能开动率×合格品率", "source": "MES", "rule": "每低1%扣2分，低于75%得0分", "cycle": "月度"},
            {"id": "KPI-MF-S05", "name": "安全生产", "weight": 10, "target": "0 起", "formula": "责任安全事故起数", "source": "安全部门", "rule": "每发生一起扣5分，重大事故0分", "cycle": "月度"},
            {"id": "KPI-MF-S06", "name": "团队培训覆盖率", "weight": 10, "target": "≥100%", "formula": "参训人数/应训人数×100%", "source": "培训记录", "rule": "每低5%扣2分，低于80%得0分", "cycle": "季度"}
          ]
        }
      }
