      "positions": {
        "电商运营助理": {
          "note": "与 prajna-salary-template 中「互联网-电商运营助理」KPI 思路保持一致",
          "kpis": [
            {"id": "KPI-EO-01", "name": "销售额/GMV 达成率", "weight": 25, "target": "≥85%", "formula": "实际销售额/目标销售额×100%", "source": "电商后台/ERP", "rule": "每低1%扣2分，低于70%得0分", "cycle": "月度"},
            {"id": "KPI-EO-02", "name": "用户增长/活跃度", "weight": 20, "target": "≥88%", "formula": "实际新增用户数/目标×100% 或 DAU 达成率", "source": "数据分析平台", "rule": "每低1%扣2分，低于75%得0分", "cycle": "月度"},
            {"id": "KPI-EO-03", "name": "活动执行完成率", "weight": 15, "target": "≥95%", "formula": "按时完成活动数/计划活动数×100%", "source": "运营日历", "rule": "每低1%扣3分，低于85%得0分", "cycle": "月度"},
            {"id": "KPI-EO-04", "name": "内容/商品质量", "weight": 15, "target": "≥88%", "formula": "内容/商品审核合格率或评分", "source": "平台后台/质检表", "rule": "每低1%扣2分，低于75%得0分", "cycle": "月度"},
            {"id": "KPI-EO-05", "name": "数据分析准确率", "weight": 15, "target": "≥90%", "formula": "准确报表数/总报表数×100%", "source": "报表抽检", "rule": "每低1%扣2分，低于80%得0分", "cycle": "月度"},
            {"id": "KPI-EO-06", "name": "渠道拓展与维护", "weight": 10, "target": "≥85%", "formula": "目标渠道数达成率或渠道评分", "source": "渠道管理表", "rule": "每低1%扣2分，低于70%得0分", "cycle": "季度"}
          ]
        },
        "电商运营经理": {
          "kpis": [
            {"id": "KPI-EO-M01", "name": "部门 GMV 达成率", "weight": 30, "target": "≥100%", "formula": "实际 GMV/目标 GMV×100%", "source": "电商后台", "rule": "每低1%扣2分，低于85%得0分", "cycle": "季度"},
            {"id": "KPI-EO-M02", "name": "运营费用率", "weight": 20, "target": "≤8%", "formula": "运营费用/GMV×100%", "source": "财务系统", "rule": "每超0.5%扣3分，高于12%得0分", "cycle": "月度"},
            {"id": "KPI-EO-M03", "name": "团队人均产出", "weight": 20, "target": "≥定额95%", "formula": "GMV/团队人数", "source": "HR与运营数据", "rule": "每低1%扣2分，低于80%得0分", "cycle": "季度"},
            {"id": "KPI-EO-M04", "name": "重点项目上线质量", "weight": 15, "target": "≥90%", "formula": "按时高质量上线项目数/总数", "source": "项目管理表", "rule": "每低1%扣2分，低于75%得0分", "cycle": "季度"},
            {"id": "KPI-EO-M05", "name": "团队培养与留存", "weight": 15, "target": "核心流失率≤10%", "formula": "核心员工离职人数/核心人数×100%", "source": "HR系统", "rule": "每超1%扣3分，高于20%得0分", "cycle": "季度"}
          ]
        }
      }
