            {"id": "KPI-MF-02", "name": "质量合格率", "weight": 25, "target": "≥98%", "formula": "合格数/总检验数×100%", "source": "品检日报/返修记录", "rule": "每低0.5%扣3分，低于93%得0分", "cycle": "月度"},
